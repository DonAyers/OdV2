---
import { getCollection, render } from 'astro:content';
import BlogPost from '../../../layouts/BlogPost.astro';
import { client } from '../../../../tina/__generated__/client';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => {
    const parts = post.id.split('/');
    const lang = parts[0];
    const slug = parts.slice(1).join('/').replace(/\.(md|mdx)$/, '');
    return {
      params: { lang, slug },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const relativePath = `${post.id}.md`;
let tinaProps: Awaited<ReturnType<typeof client.queries.blog>> | null = null;

try {
  tinaProps = await client.queries.blog({ relativePath });
} catch {
  tinaProps = null;
}

const renderedPost = tinaProps ? null : await render(post);
const Content = renderedPost?.Content;
---

<BlogPost
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  category={post.data.category}
  tags={post.data.tags}
  heroImage={post.data.heroImage}
  translationSlug={post.data.translationSlug}
  tinaProps={tinaProps}
>
  {Content && <Content />}
</BlogPost>
