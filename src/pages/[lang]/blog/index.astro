---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../../../i18n/utils';
import { getCollection } from 'astro:content';

export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'it' } }];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((post) => post.data.lang === lang)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function categoryClass(cat?: string) {
  if (cat === 'americas') return 'category-badge category-badge-americas';
  return 'category-badge category-badge-oddities';
}

function getSlug(id: string) {
  return id.split('/').slice(1).join('/').replace(/\.(md|mdx)$/, '');
}
---

<BaseLayout title={`${t('blog.title')} — ${t('site.title')}`} description={t('site.description')}>

  <!-- Page header -->
  <div class="bg-white border-b border-cream-200">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12">
      <p class="text-terra-500 font-sans text-xs font-bold uppercase tracking-widest mb-2">
        Od's Travel Log
      </p>
      <h1 class="font-serif text-3xl md:text-4xl font-bold text-ink-900">
        {t('blog.title')}
      </h1>
    </div>
  </div>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12">

    {posts.length === 0 ? (
      <p class="text-ink-400 text-center py-12">{t('blog.noPosts')}</p>
    ) : (
      <ul class="space-y-6">
        {posts.map((post) => {
          const slug = getSlug(post.id);
          return (
            <li>
              <a
                href={getLocalizedPath(lang, `/blog/${slug}`)}
                class="group flex gap-6 bg-white rounded-2xl border border-cream-200
                       p-6 hover:shadow-md hover:border-cream-300 transition-all duration-200"
              >
                <!-- Category color strip -->
                <div class:list={[
                  'hidden sm:block w-1 rounded-full flex-shrink-0',
                  post.data.category === 'americas' ? 'bg-sage-500' : 'bg-terra-400'
                ]}></div>

                <div class="flex-1 min-w-0">
                  <div class="flex flex-wrap items-center gap-2 mb-2">
                    {post.data.category && (
                      <span class={categoryClass(post.data.category)}>{post.data.category}</span>
                    )}
                    <span class="text-ink-400 text-xs font-sans">
                      <FormattedDate date={post.data.pubDate} lang={lang} />
                    </span>
                  </div>

                  <h2 class="font-serif text-xl font-semibold text-ink-900 leading-snug mb-2
                             group-hover:text-terra-700 transition-colors">
                    {post.data.title}
                  </h2>

                  {post.data.description && (
                    <p class="text-ink-500 text-sm leading-relaxed line-clamp-2 font-body">
                      {post.data.description}
                    </p>
                  )}

                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-1.5 mt-3">
                      {post.data.tags.slice(0, 4).map((tag: string) => (
                        <span class="tag-pill">{tag}</span>
                      ))}
                      {post.data.tags.length > 4 && (
                        <span class="tag-pill">+{post.data.tags.length - 4}</span>
                      )}
                    </div>
                  )}
                </div>

                <div class="hidden md:flex items-center flex-shrink-0 text-terra-500 group-hover:text-terra-700 transition-colors">
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M4 10h12M11 5l5 5-5 5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
              </a>
            </li>
          );
        })}
      </ul>
    )}
  </div>

</BaseLayout>
