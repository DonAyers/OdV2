---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../../i18n/utils';
import { getCollection } from 'astro:content';

export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'it' } }];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((post) => post.data.lang === lang)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const [featured, ...rest] = posts;

function categoryClass(cat?: string) {
  if (cat === 'americas') return 'category-badge category-badge-americas';
  return 'category-badge category-badge-oddities';
}

function getSlug(id: string) {
  return id.split('/').slice(1).join('/').replace(/\.(md|mdx)$/, '');
}
---

<BaseLayout title={t('site.title')} description={t('site.description')}>

  <!-- ── Hero ──────────────────────────────────────────────────────── -->
  <section class="bg-ink-900 text-cream-100 relative overflow-hidden">
    <!-- Decorative world map dots background -->
    <div class="absolute inset-0 opacity-5 bg-[radial-gradient(circle,_#fff_1px,_transparent_1px)] bg-[size:24px_24px]" aria-hidden="true"></div>
    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 py-24 md:py-32">
      <p class="text-terra-400 font-sans text-sm font-semibold uppercase tracking-widest mb-4">
        Barbara Burgio
      </p>
      <h1 class="font-serif text-4xl md:text-6xl font-bold leading-tight text-cream-50 mb-6 max-w-2xl">
        {t('home.welcome')}
      </h1>
      <p class="text-lg text-ink-200 max-w-xl leading-relaxed">
        {t('home.subtitle')}
      </p>
      <a
        href={getLocalizedPath(lang, '/blog')}
        class="inline-flex items-center gap-2 mt-8 px-5 py-2.5 bg-terra-500 hover:bg-terra-600
               text-white font-sans text-sm font-semibold rounded-full transition-colors"
      >
        {t('blog.title')} →
      </a>
    </div>
  </section>

  <!-- ── Featured Post ────────────────────────────────────────────── -->
  {featured && (
    <section class="max-w-5xl mx-auto px-4 sm:px-6 py-16">
      <div class="flex items-center gap-3 mb-8">
        <span class="text-terra-500 font-sans text-xs font-bold uppercase tracking-widest">
          {t('home.latestPosts')}
        </span>
        <div class="flex-1 border-t border-cream-300"></div>
      </div>

      <a
        href={getLocalizedPath(lang, `/blog/${getSlug(featured.id)}`)}
        class="group block bg-white rounded-3xl overflow-hidden shadow-sm border border-cream-200
               hover:shadow-lg transition-all duration-300 md:flex"
      >
        <div class="md:w-72 md:flex-shrink-0 min-h-40 md:min-h-full bg-gradient-to-br from-terra-100 to-cream-200 overflow-hidden">
          {featured.data.heroImage ? (
            <img
              src={featured.data.heroImage}
              alt={featured.data.title}
              class="w-full h-full object-cover"
            />
          ) : (
            <div class="w-full h-full flex items-center justify-center">
              <span class="text-6xl opacity-60" aria-hidden="true">
                {featured.data.category === 'americas' ? '🌎' : '🔭'}
              </span>
            </div>
          )}
        </div>
        <div class="p-8 flex flex-col justify-center flex-1">
          <div class="flex items-center gap-3 mb-3">
            {featured.data.category && (
              <span class={categoryClass(featured.data.category)}>{featured.data.category}</span>
            )}
            <span class="text-ink-400 text-sm font-sans">
              <FormattedDate date={featured.data.pubDate} lang={lang} />
            </span>
          </div>
          <h2 class="font-serif text-2xl md:text-3xl font-semibold text-ink-900 leading-snug mb-3
                     group-hover:text-terra-700 transition-colors">
            {featured.data.title}
          </h2>
          {featured.data.description && (
            <p class="text-ink-500 leading-relaxed mb-4 font-body">{featured.data.description}</p>
          )}
          <span class="text-terra-600 font-sans text-sm font-semibold group-hover:text-terra-700">
            {t('blog.readMore')} →
          </span>
        </div>
      </a>
    </section>
  )}

  <!-- ── More Posts Grid ──────────────────────────────────────────── -->
  {rest.length > 0 && (
    <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-20">
      <ul class="grid sm:grid-cols-2 lg:grid-cols-2 gap-6">
        {rest.map((post) => (
          <li>
            <a href={getLocalizedPath(lang, `/blog/${getSlug(post.id)}`)} class="post-card h-full flex flex-col">
              <!-- Color band -->
              <div class:list={[
                'h-2 w-full',
                post.data.category === 'americas' ? 'bg-sage-500' : 'bg-terra-400'
              ]}></div>
              <div class="post-card-body flex-1 flex flex-col">
                <div class="flex items-center gap-2 mb-3">
                  {post.data.category && (
                    <span class={categoryClass(post.data.category)}>{post.data.category}</span>
                  )}
                  <span class="text-ink-400 text-xs font-sans ml-auto">
                    <FormattedDate date={post.data.pubDate} lang={lang} />
                  </span>
                </div>
                <h3 class="post-card-title flex-1">{post.data.title}</h3>
                {post.data.description && (
                  <p class="text-ink-500 text-sm leading-relaxed mt-2 line-clamp-2">{post.data.description}</p>
                )}
                <span class="mt-4 text-terra-600 font-sans text-xs font-semibold group-hover:text-terra-700">
                  {t('blog.readMore')} →
                </span>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  {posts.length === 0 && (
    <div class="max-w-5xl mx-auto px-4 py-16 text-center text-ink-400">
      {t('blog.noPosts')}
    </div>
  )}

</BaseLayout>
