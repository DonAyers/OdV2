---
const target = '/en/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Redirecting...</title>
    <link rel="canonical" href={target} />
    <meta http-equiv="refresh" content={`0;url=${target}`} />
    <script is:inline>
      window.location.replace('/en/');
    </script>
  </head>
  <body>
    <noscript>
      <a href={target}>Continue to the English site.</a>
    </noscript>
  </body>
</html>
