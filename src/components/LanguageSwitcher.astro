---
import { languages } from '../i18n/ui';
import { getLangFromUrl, getOtherLang } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const otherLang = getOtherLang(lang);
const currentPath = Astro.url.pathname;
const otherPath = currentPath.replace(`/${lang}`, `/${otherLang}`);

const flags: Record<string, string> = { en: '🇬🇧', it: '🇮🇹' };
---

<a
  href={otherPath}
  class="flex items-center gap-1.5 text-sm font-medium px-3 py-1.5 rounded-full
         bg-cream-200 text-ink-700 hover:bg-terra-100 hover:text-terra-800
         border border-cream-300 hover:border-terra-300
         transition-all duration-150"
  title={`Switch to ${languages[otherLang]}`}
>
  <span aria-hidden="true">{flags[lang]}</span>
  <span class="hidden sm:inline">{lang.toUpperCase()}</span>
</a>
